<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="com.github.williwadelmawisky.musicplayer.scene.pages.PlaylistOpenPage"
         xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
         spacing="10"
>
    <padding>
        <Insets topRightBottomLeft="10"/>
    </padding>
    <HBox spacing="5">
        <TextField promptText="Search..." HBox.hgrow="ALWAYS" maxWidth="1000"/>
        <Button text="Search"/>
    </HBox>
    <ScrollPane maxHeight="600" fitToWidth="true">
        <VBox>
            <padding>
                <Insets topRightBottomLeft="5"/>
            </padding>
            <VBox spacing="5" fx:id="_playlistBox"/>
        </VBox>
    </ScrollPane>
</fx:root>
