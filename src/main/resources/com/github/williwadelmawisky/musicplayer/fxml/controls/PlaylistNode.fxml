<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="com.github.williwadelmawisky.musicplayer.scene.controls.PlaylistNode"
         xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
         styleClass="content-box" alignment="CENTER_LEFT"
>
    <padding>
        <Insets left="15" top="10" right="15" bottom="10"/>
    </padding>
    <Label fx:id="_nameLabel"/>
    <Region HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    <Button text="Open" onAction="#onButtonClicked"/>
</fx:root>
