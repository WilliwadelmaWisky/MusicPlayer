<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="com.github.williwadelmawisky.musicplayer.scene.pages.NewPlaylistPage"
         xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
         spacing="10"
>
    <padding>
        <Insets topRightBottomLeft="10"/>
    </padding>
    <Label text="Name"/>
    <TextField promptText="Enter a name..." fx:id="_nameTextField"/>
    <Label text="Songs"/>
    <Button text="Add" onAction="#onAddButtonClicked"/>
    <Button text="Remove" onAction="#onRemoveButtonClicked"/>
    <ListView fx:id="_songVBox" VBox.vgrow="ALWAYS" maxHeight="1000"/>
    <HBox alignment="CENTER_RIGHT" spacing="5">
        <Button text="Apply" onAction="#onApplyButtonClicked"/>
        <Button text="Cancel" onAction="#onCancelButtonClicked"/>
    </HBox>
</fx:root>
